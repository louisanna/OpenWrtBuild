
config system
	option hostname 'RaspberryPi'
	option timezone 'CST-8'
	option zonename 'Asia/Shanghai'
	option ttylogin '0'
	option log_size '128'
	option urandom_seed '0'
	option log_proto 'udp'
	option conloglevel '4'
	option cronloglevel '7'

config timeserver 'ntp'
	list server 'ntp.ntsc.ac.cn'
	list server 'ntp.cnnic.cn'
	list server 'cn.ntp.org.cn'
	list server 'ntp1.nim.ac.cn'
	list server 'cn.pool.ntp.org'
	option use_dhcp '0'

